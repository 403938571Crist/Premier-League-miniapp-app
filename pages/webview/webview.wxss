web-view {
  width: 100%;
  height: 100vh;
}

.fallback-page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  background: #f5f5f7;
}

.fallback-card {
  margin-top: 120rpx;
  padding: 40rpx 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 32rpx rgba(17, 17, 19, 0.08);
}

.fallback-title {
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1f1f22;
}

.fallback-desc {
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #5d5d66;
}

.fallback-url {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f7f3f9;
  font-size: 22rpx;
  line-height: 1.6;
  color: #38003c;
  word-break: break-all;
}

.fallback-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.fallback-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0edf2;
  color: #38003c;
  font-size: 28rpx;
  font-weight: 600;
}

.fallback-btn-primary {
  background: #38003c;
  color: #ffffff;
}
