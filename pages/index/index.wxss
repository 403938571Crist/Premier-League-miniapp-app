.container {
  padding: 16rpx 30rpx 36rpx;
  background-color: #F5F5F7;
}

.featured-section {
  margin-bottom: 32rpx;
  margin-top: 0;
}

.featured-shell {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
}

.featured-swiper {
  height: 380rpx;
  border-radius: 32rpx;
}

.featured-card-wrap {
  height: 100%;
  border-radius: 32rpx;
  overflow: hidden;
}

.featured-pagination {
  position: absolute;
  left: 50%;
  bottom: 18rpx;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 10rpx;
  z-index: 4;
}

.featured-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.28);
}

.featured-dot.is-active {
  background: #ffffff;
  box-shadow: 0 0 8rpx rgba(255, 255, 255, 0.4);
}

.quick-access {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.quick-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx 22rpx;
  background-color: rgba(255, 255, 255, 0.98);
  border-radius: 16rpx;
  box-shadow: 0 10rpx 28rpx rgba(18, 18, 22, 0.05);
  box-sizing: border-box;
}

.quick-item:active {
  transform: scale(0.98);
}

.quick-icon-wrap {
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 38rpx;
  background-color: rgba(56, 0, 60, 0.05);
  margin-bottom: 14rpx;
}

.quick-icon {
  width: 42rpx;
  height: 42rpx;
}

.quick-text {
  font-size: 26rpx;
  line-height: 1.25;
  color: #2C2C2E;
  font-weight: 600;
}

.quick-subtext {
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.2;
  color: #8E8E93;
}

.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 68rpx;
  margin-bottom: 12rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #1F1F22;
}

.section-icon-wrap {
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cache-tip {
  padding: 14rpx 18rpx;
  margin-bottom: 18rpx;
  background-color: rgba(255, 152, 0, 0.1);
  border-radius: 12rpx;
}

.cache-tip text {
  font-size: 22rpx;
  color: #FF9800;
}

.news-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.news-card {
  background-color: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 0;
  overflow: hidden;
  box-shadow: 0 14rpx 34rpx rgba(17, 17, 19, 0.07);
}

.news-cover {
  padding: 0;
  border-radius: 0;
  margin-bottom: 0;
  color: #FFFFFF;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
}

.news-cover-image-shell {
  background: linear-gradient(135deg, #4b2f7f 0%, #7a5cff 100%);
}

.news-cover-placeholder-shell {
  height: 260rpx;
}

.news-cover-live {
  height: auto;
  background: #12041c;
}

.news-cover-img {
  width: 100%;
  display: block;
  border-radius: 0;
  z-index: 2;
  transition: opacity 180ms ease;
}

.news-cover-placeholder-shell .news-cover-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.news-cover-live .news-cover-img {
  position: relative;
  height: auto;
}

.news-cover-img.is-hidden {
  opacity: 0;
  pointer-events: none;
}

.news-cover-img.is-ready {
  opacity: 1;
}

.news-cover-overlay {
  position: absolute;
  inset: 0;
  padding: 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: linear-gradient(180deg, rgba(31, 8, 35, 0.18) 0%, rgba(31, 8, 35, 0.02) 38%, rgba(31, 8, 35, 0.26) 100%);
  border-radius: 0;
  box-sizing: border-box;
  z-index: 3;
}

.news-card-body {
  padding: 18rpx 18rpx 26rpx;
}

.news-cover-live .news-cover-placeholder {
  display: none;
}

.news-cover-placeholder {
  position: absolute;
  inset: 0;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background:
    radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.16) 0, rgba(255, 255, 255, 0) 34%),
    radial-gradient(circle at 82% 78%, rgba(0, 255, 133, 0.18) 0, rgba(0, 255, 133, 0) 28%),
    linear-gradient(135deg, rgba(23, 4, 28, 0.2) 0%, rgba(23, 4, 28, 0.02) 100%);
}

.news-cover-placeholder-badge {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(8rpx);
}

.news-cover-placeholder-source {
  max-width: 80%;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: rgba(255, 255, 255, 0.82);
  text-transform: uppercase;
}

.news-cover-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx;
  max-width: 220rpx;
  padding: 0 18rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #00ff85 0%, #14f195 100%);
  color: #18051c;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 0.8rpx;
}

.news-cover-official {
  background: linear-gradient(135deg, #38003C 0%, #5B0B62 100%);
}

.news-cover-dongqiudi {
  background: linear-gradient(135deg, #3044A5 0%, #5B6CFF 100%);
}

.news-cover-bilibili {
  background: linear-gradient(135deg, #D6407A 0%, #FF7BA6 100%);
}

.news-cover-douyin {
  background: linear-gradient(135deg, #111111 0%, #FE2C55 100%);
}

.news-cover-zhibo8 {
  background: linear-gradient(135deg, #8B1A04 0%, #E8380D 100%);
}

.news-cover-media {
  background: linear-gradient(135deg, #4B2F7F 0%, #7A5CFF 100%);
}

.news-cover-romano {
  background: linear-gradient(135deg, #523300 0%, #C98B10 100%);
}

.news-cover-x {
  background: linear-gradient(135deg, #111111 0%, #3B3B3B 100%);
}

.news-cover-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.news-cover-tag,
.news-cover-type {
  min-height: 34rpx;
  padding: 0 12rpx;
  border-radius: 18rpx;
  display: inline-flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.14);
  font-size: 18rpx;
  font-weight: 700;
}

.news-cover-body {
  display: flex;
  align-items: flex-end;
  margin-top: 34rpx;
}

.news-cover-icon {
  width: 72rpx;
  height: 72rpx;
  margin-right: 16rpx;
  opacity: 0.9;
  filter: brightness(0) invert(1);
  flex-shrink: 0;
}

.news-cover-copy {
  flex: 1;
  min-width: 0;
}

.news-cover-source {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.78);
}

.news-cover-title {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1.34;
  color: #FFFFFF;
  font-weight: 700;
}

.news-card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.news-tag {
  display: inline-flex;
  align-items: center;
  min-height: 36rpx;
  padding: 0 14rpx;
  border-radius: 18rpx;
  background-color: rgba(56, 0, 60, 0.08);
  color: #38003C;
  font-size: 20rpx;
  font-weight: 700;
}

.news-date {
  font-size: 22rpx;
  color: #8E8E93;
}

.news-card-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.18;
  color: #3d0d4a;
  font-weight: 800;
  margin-bottom: 14rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-card-summary {
  display: block;
  font-size: 24rpx;
  line-height: 1.62;
  color: #6a6170;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.news-source {
  font-size: 22rpx;
  color: #9b90a3;
  letter-spacing: 0.6rpx;
}

.social-section {
  margin-top: 6rpx;
}

.social-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.social-card {
  display: flex;
  align-items: center;
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.98);
  box-shadow: 0 10rpx 28rpx rgba(17, 17, 19, 0.05);
}

.social-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #38003C 0%, #5A1463 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.social-main {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.social-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.social-name {
  font-size: 28rpx;
  color: #1F1F22;
  font-weight: 700;
}

.social-platform {
  font-size: 20rpx;
  color: #38003C;
  font-weight: 700;
}

.social-handle {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8E8E93;
}

.social-summary {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #666666;
}

.social-arrow {
  width: 22rpx;
  height: 22rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}
