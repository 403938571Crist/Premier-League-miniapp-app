/* 基础重置 */
page {
  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  color: #333333;
  font-size: 28rpx;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* 通用容器 */
.container {
  padding: 0 30rpx 30rpx;
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.card-title-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* 通用列表 */
.list {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
}

.list-item {
  display: flex;
  align-items: center;
  min-height: 100rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #E5E5E5;
  box-sizing: border-box;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item:active {
  background-color: #F5F5F5;
}

/* 文字省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 按钮样式 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  padding: 0 48rpx;
  font-size: 28rpx;
  border-radius: 32rpx;
  border: none;
  outline: none;
  transition: opacity 0.2s;
}

.btn:active {
  opacity: 0.8;
}

.btn-primary {
  background-color: #38003C;
  color: #FFFFFF;
}

.btn-secondary {
  background-color: #F5F5F5;
  color: #666666;
  border: 1rpx solid #E5E5E5;
}

.btn-accent {
  background-color: #00FF85;
  color: #38003C;
  font-weight: bold;
}

.btn-disabled {
  background-color: #E0E0E0;
  color: #999999;
}

/* 分组标题 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #666666;
}

.section-title {
  display: flex;
  align-items: center;
  font-weight: bold;
  color: #333333;
}

.section-icon {
  margin-right: 8rpx;
}

.section-more {
  display: flex;
  align-items: center;
  color: #999999;
  font-size: 24rpx;
}

.arrow-right::after {
  content: '';
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid currentColor;
  border-right: 2rpx solid currentColor;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  font-size: 20rpx;
  border-radius: 8rpx;
  line-height: 1.2;
}

.tag-primary {
  background-color: #38003C;
  color: #FFFFFF;
}

.tag-accent {
  background-color: #00FF85;
  color: #38003C;
}

.tag-default {
  background-color: #F5F5F5;
  color: #666666;
}

.tag-live {
  background-color: #00FF85;
  color: #38003C;
  font-weight: bold;
}

.tag-live::before {
  content: '';
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  background-color: #38003C;
  border-radius: 50%;
  margin-right: 8rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

/* 状态标识 */
.status {
  font-size: 24rpx;
  color: #666666;
}

.status-live {
  color: #00FF85;
  font-weight: bold;
}

.status-pending {
  color: #999999;
}

.status-finished {
  color: #666666;
}

.status-delayed {
  color: #FF5252;
}

/* 加载动画 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #E5E5E5;
  border-top-color: #38003C;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #999999;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #E5E5E5;
  margin: 20rpx 0;
}

/* 间距工具类 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }

.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }

.ml-10 { margin-left: 10rpx; }
.ml-20 { margin-left: 20rpx; }

.mr-10 { margin-right: 10rpx; }
.mr-20 { margin-right: 20rpx; }

/* 文字对齐 */
.text-left { text-align: left; }
.text-center { text-align: center; }
.text-right { text-align: right; }

/* 文字颜色 */
.text-primary { color: #38003C; }
.text-accent { color: #00FF85; }
.text-main { color: #333333; }
.text-secondary { color: #666666; }
.text-muted { color: #999999; }
.text-success { color: #43A047; }
.text-warning { color: #FF9800; }
.text-error { color: #FF5252; }

/* 文字粗细 */
.font-normal { font-weight: normal; }
.font-bold { font-weight: bold; }

/* 文字大小 */
.text-xs { font-size: 20rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 40rpx; }
.text-3xl { font-size: 48rpx; }

/* flex 布局 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.items-end { align-items: flex-end; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.justify-around { justify-content: space-around; }
.flex-1 { flex: 1; }
.flex-shrink-0 { flex-shrink: 0; }

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  background: transparent;
}
