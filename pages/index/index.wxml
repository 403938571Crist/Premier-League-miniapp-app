<view class="container">
  <loading-state wx:if="{{loading && !featuredMatches.length}}"></loading-state>

  <error-state
    wx:elif="{{error}}"
    title="{{error.title}}"
    description="{{error.description}}"
    bind:retry="loadData">
  </error-state>

  <block wx:else>
    <view class="featured-section" wx:if="{{featuredMatches.length > 0}}">
      <view class="featured-head">
        <view class="featured-copy">
          <text class="featured-eyebrow">MATCHDAY FOCUS</text>
          <text class="featured-title">焦点比赛</text>
        </view>
        <view class="featured-badge">
          <text>{{featuredMatches.length}} 场</text>
        </view>
      </view>
      <view class="featured-shell">
        <swiper
          class="featured-swiper"
          indicator-dots
          autoplay="{{false}}"
          circular="{{false}}"
          duration="220">
          <swiper-item wx:for="{{featuredMatches}}" wx:key="id">
            <view class="featured-card-wrap">
              <match-card
                match="{{item}}"
                is-highlight="{{true}}"
                bind:tap="onMatchTap">
              </match-card>
            </view>
          </swiper-item>
        </swiper>
      </view>
    </view>

    <view class="quick-access">
      <view class="quick-item" bindtap="goToStandings">
        <view class="quick-icon-wrap">
          <image class="quick-icon" src="/images/icons/trophy.png" mode="aspectFit"></image>
        </view>
        <text class="quick-text">积分榜</text>
        <text class="quick-subtext">实时排名</text>
      </view>
      <view class="quick-item" bindtap="goToFixtures">
        <view class="quick-icon-wrap">
          <image class="quick-icon" src="/images/icons/calendar.png" mode="aspectFit"></image>
        </view>
        <text class="quick-text">赛程</text>
        <text class="quick-subtext">比赛日历</text>
      </view>
      <view class="quick-item" bindtap="goToTeams">
        <view class="quick-icon-wrap">
          <image class="quick-icon" src="/images/icons/team.png" mode="aspectFit"></image>
        </view>
        <text class="quick-text">球队</text>
        <text class="quick-subtext">俱乐部档案</text>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-title">
          <image class="section-icon" src="/images/icons/list.png" mode="aspectFit"></image>
          <text>英超资讯</text>
        </view>
      </view>

      <view class="cache-tip" wx:if="{{isCached}}">
        <text>数据来自缓存 · {{cacheTime}}</text>
      </view>

      <view class="news-list" wx:if="{{newsItems.length > 0}}">
        <view
          class="news-card"
          wx:for="{{newsItems}}"
          wx:key="id"
          bindtap="onNewsTap"
          data-id="{{item.id}}">
          <view class="news-cover news-cover-image-shell news-cover-{{item._coverThemeResolved}} {{item._coverState === 'ready' ? 'news-cover-live' : 'news-cover-placeholder-shell'}}">
            <view class="news-cover-placeholder">
              <view class="news-cover-placeholder-badge">
                <image class="news-cover-placeholder-icon" src="/images/icons/news.png" mode="aspectFit"></image>
              </view>
              <text class="news-cover-placeholder-source">{{item.source || 'Premier League'}}</text>
            </view>
            <image
              wx:if="{{item.coverImage}}"
              class="news-cover-img {{item._coverState === 'ready' ? 'is-ready' : 'is-hidden'}}"
              src="{{item.coverImage}}"
              mode="widthFix"
              bindload="onNewsImageLoad"
              binderror="onNewsImageError"
              data-index="{{index}}"
              lazy-load>
            </image>
            <view class="news-cover-overlay">
              <view class="news-cover-top">
                <text class="news-cover-chip">{{item.tag}}</text>
              </view>
            </view>
          </view>
          <view class="news-card-body">
            <view class="news-card-head">
              <text class="news-tag">{{item.source}}</text>
              <text class="news-date">{{item.publishedAt}}</text>
            </view>
            <text class="news-card-title">{{item.title}}</text>
            <text class="news-card-summary">{{item.summary}}</text>
            <view class="news-card-footer">
              <text class="news-source">{{item.mediaType}}</text>
              <image class="news-arrow" src="/images/icons/arrow-right.png" mode="aspectFit"></image>
            </view>
          </view>
        </view>
      </view>

      <view class="load-more" wx:if="{{newsItems.length > 0}}">
        <view wx:if="{{newsLoadingMore}}">
          <text class="load-more-text">加载中...</text>
        </view>
        <view wx:elif="{{!newsHasMore}}">
          <text class="load-more-text load-more-end">没有更多了</text>
        </view>
      </view>

      <empty-state
        wx:elif="{{!newsItems.length}}"
        title="暂无资讯"
        description="稍后再来看最新英超动态">
      </empty-state>
    </view>
  </block>
</view>
