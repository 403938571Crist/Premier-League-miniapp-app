.container {
  padding: 0 30rpx 30rpx;
}

/* 球员头部 */
.player-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  margin: 20rpx 0;
}

.player-photo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background-color: #F5F5F5;
  margin-bottom: 24rpx;
}

.player-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.player-subtitle {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.player-position {
  font-size: 24rpx;
  color: #38003C;
  background-color: rgba(56, 0, 60, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.separator {
  font-size: 24rpx;
  color: #999999;
  margin: 0 12rpx;
}

.player-nationality {
  font-size: 24rpx;
  color: #666666;
}

.player-team {
  margin-top: 8rpx;
}

.player-team text {
  font-size: 28rpx;
  color: #38003C;
  text-decoration: underline;
}

.card-title-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

/* 基本信息列表 */
.info-list {
  margin-top: 10rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E5E5E5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* 核心数据 */
.core-stats {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
}

.core-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.core-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.core-label {
  font-size: 24rpx;
  color: #666666;
}

.stats-divider {
  height: 1rpx;
  background-color: #E5E5E5;
  margin: 10rpx 0;
}

/* 数据说明 */
.data-note {
  display: flex;
  align-items: flex-start;
  margin-top: 30rpx;
  padding: 20rpx 24rpx;
  background-color: rgba(255, 152, 0, 0.1);
  border-radius: 8rpx;
}

.data-note-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
  margin-top: 2rpx;
  flex-shrink: 0;
}

.data-note text {
  flex: 1;
  font-size: 24rpx;
  color: #FF9800;
  line-height: 1.5;
}
