.match-card {
  width: 100%;
  box-sizing: border-box;
  background-color: #ffffff;
  border-radius: 22rpx;
  padding: 24rpx 24rpx 22rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 16rpx 36rpx rgba(17, 17, 19, 0.05);
}

.match-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.match-datetime {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.match-date {
  font-size: 18rpx;
  line-height: 1.2;
  color: #b0b0b5;
}

.match-time {
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
  color: #2c2c2e;
  letter-spacing: -0.6rpx;
}

.match-day {
  font-size: 22rpx;
  line-height: 1.2;
  color: #a0a0a8;
}

.match-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-bottom: 26rpx;
}

.team {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.team-logo {
  width: 82rpx;
  height: 82rpx;
  margin-bottom: 14rpx;
}

.team-name {
  max-width: 166rpx;
  font-size: 28rpx;
  line-height: 1.34;
  color: #404043;
  text-align: center;
}

.score-section {
  flex: 0 0 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score {
  min-width: 44rpx;
  text-align: center;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 700;
  color: #2c2c2e;
}

.score.pending {
  color: #c2c2c8;
}

.score.live {
  color: #00d977;
}

.score-divider {
  margin: 0 14rpx;
  font-size: 36rpx;
  line-height: 1;
  color: #a7a7af;
}

.score-divider.pending {
  color: #d2d2d7;
}

.score-divider.live {
  color: #00d977;
}

.match-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status {
  font-size: 24rpx;
  line-height: 1.2;
}

.status-pending {
  color: #8e8e93;
}

.status-finished {
  color: #666666;
}

.status-delayed {
  color: #ff5252;
}

.status-live {
  display: flex;
  align-items: center;
}

.live-dot {
  width: 10rpx;
  height: 10rpx;
  margin-right: 8rpx;
  border-radius: 50%;
  background-color: #00ff85;
  animation: pulse 1.5s ease-in-out infinite;
}

.live-text {
  font-size: 24rpx;
  line-height: 1.2;
  color: #00d977;
  font-weight: 600;
}

.competition {
  font-size: 22rpx;
  line-height: 1.2;
  color: #b0b0b5;
}

@keyframes pulse {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0.35;
  }
}

.match-card.highlight {
  position: relative;
  height: 100%;
  margin-bottom: 0;
  padding: 22rpx 26rpx 26rpx;
  border-radius: 32rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background:
    radial-gradient(circle at 14% 8%, rgba(103, 183, 255, 0.17) 0, rgba(103, 183, 255, 0.05) 12%, rgba(103, 183, 255, 0) 28%),
    radial-gradient(circle at 88% 8%, rgba(214, 72, 103, 0.11) 0, rgba(214, 72, 103, 0) 22%),
    radial-gradient(circle at 50% 130%, rgba(0, 255, 133, 0.09) 0, rgba(0, 255, 133, 0) 30%),
    linear-gradient(160deg, #4a0554 0%, #3b0144 55%, #220028 100%);
  box-shadow: 0 18rpx 42rpx rgba(29, 0, 33, 0.24);
  box-sizing: border-box;
  color: #ffffff;
}

.match-card.fixtures {
  position: relative;
  padding: 18rpx 22rpx 20rpx;
  border-radius: 26rpx;
  box-shadow: 0 18rpx 36rpx rgba(26, 18, 31, 0.08);
}

.match-card.fixtures.is-live::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  height: 6rpx;
  border-radius: 26rpx 26rpx 0 0;
  background: #00ff85;
}

.fixtures-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.fixtures-meta {
  font-size: 18rpx;
  color: #c2b8c7;
  font-weight: 700;
  letter-spacing: 1.4rpx;
}

.fixtures-state {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 0.6rpx;
  color: #c2b8c7;
}

.fixtures-state.status-live {
  color: #00d977;
}

.fixtures-state.status-finished {
  color: #a8a0ae;
}

.fixtures-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.fixtures-team {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.fixtures-logo-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #faf8fb;
  border: 1rpx solid #f0ebf2;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.fixtures-logo {
  width: 56rpx;
  height: 56rpx;
}

.fixtures-team-name {
  max-width: 150rpx;
  text-align: center;
  font-size: 28rpx;
  line-height: 1.32;
  color: #451d4f;
  font-weight: 600;
}

.fixtures-score {
  flex: 0 0 176rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fixtures-score-value {
  min-width: 42rpx;
  text-align: center;
  font-size: 62rpx;
  line-height: 1;
  color: #3f114a;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.fixtures-score-value.live {
  color: #00d977;
}

.fixtures-score-divider {
  margin: 0 12rpx;
  font-size: 40rpx;
  color: #ddd7e0;
  font-weight: 600;
}

.fixtures-score-divider.live {
  color: #00d977;
}

.fixtures-kickoff-time {
  min-width: 112rpx;
  height: 56rpx;
  border-radius: 18rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5eff7;
  color: #4b2556;
  font-size: 28rpx;
  font-weight: 700;
}

.fixtures-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.fixtures-bottom-left {
  display: flex;
  align-items: center;
}

.fixtures-status-dot {
  width: 10rpx;
  height: 10rpx;
  margin-right: 8rpx;
  border-radius: 50%;
  background-color: #00ff85;
}

.fixtures-bottom-status {
  font-size: 20rpx;
  line-height: 1.2;
  color: #b2acb7;
  font-weight: 600;
}

.fixtures-bottom-status.status-live {
  color: #00d977;
}

.fixtures-bottom-status.status-finished {
  color: #a8a0ae;
}

.fixtures-bottom-status.status-delayed {
  color: #ff5252;
}

.fixtures-detail-link {
  font-size: 20rpx;
  line-height: 1.2;
  color: #4c1f57;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.hero-ambient {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.hero-glow {
  position: absolute;
  border-radius: 50%;
}

.hero-glow-left {
  left: -54rpx;
  top: -42rpx;
  width: 280rpx;
  height: 196rpx;
  background: radial-gradient(circle, rgba(102, 188, 255, 0.24) 0, rgba(102, 188, 255, 0.04) 34%, rgba(102, 188, 255, 0) 74%);
}

.hero-glow-right {
  right: -42rpx;
  top: -28rpx;
  width: 244rpx;
  height: 168rpx;
  background: radial-gradient(circle, rgba(218, 65, 92, 0.16) 0, rgba(218, 65, 92, 0) 70%);
}

.hero-pitch-glow {
  position: absolute;
  left: 50%;
  bottom: -118rpx;
  width: 460rpx;
  height: 116rpx;
  transform: translateX(-50%);
  background: radial-gradient(circle, rgba(0, 255, 133, 0.06) 0, rgba(0, 255, 133, 0) 74%);
}

.hero-texture {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.024) 0 2rpx, rgba(255, 255, 255, 0) 2rpx 11rpx);
}

.hero-midline {
  position: absolute;
  top: 40rpx;
  bottom: 40rpx;
  left: 50%;
  width: 2rpx;
  margin-left: -1rpx;
  background: rgba(255, 255, 255, 0.07);
}

.hero-circle {
  position: absolute;
  left: 50%;
  top: 54%;
  width: 188rpx;
  height: 188rpx;
  margin-left: -94rpx;
  margin-top: -94rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 50%;
}

.hero-arc {
  position: absolute;
  border: 1rpx solid rgba(0, 255, 133, 0.16);
  border-radius: 50%;
}

.hero-arc-outer {
  right: -46rpx;
  bottom: -48rpx;
  width: 156rpx;
  height: 156rpx;
}

.hero-arc-inner {
  right: -4rpx;
  bottom: -6rpx;
  width: 92rpx;
  height: 92rpx;
  opacity: 0.64;
}

.hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  height: 100%;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.hero-round {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: 10rpx;
  background: rgba(0, 255, 133, 0.13);
  border: 1rpx solid rgba(0, 255, 133, 0.2);
  box-shadow: 0 0 10rpx rgba(0, 255, 133, 0.08);
}

.hero-round-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #00ff85;
  box-shadow: 0 0 8rpx rgba(0, 255, 133, 0.34);
}

.hero-round-text {
  font-size: 19rpx;
  color: #00ff85;
  font-weight: 700;
}

.hero-datetime {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.hero-date {
  font-size: 19rpx;
  color: rgba(255, 255, 255, 0.62);
  line-height: 1.2;
  margin-bottom: 6rpx;
}

.hero-time {
  font-size: 56rpx;
  line-height: 1;
  color: #ffffff;
  font-weight: 800;
  letter-spacing: -1rpx;
}

.hero-main {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  padding: 4rpx 4rpx 0;
}

.hero-team {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-team-logo-shell {
  width: 92rpx;
  height: 92rpx;
  margin-bottom: 14rpx;
  background: transparent;
  box-shadow: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.hero-team-logo {
  width: 92rpx;
  height: 92rpx;
}

.hero-team-name {
  max-width: 170rpx;
  text-align: center;
  font-size: 31rpx;
  line-height: 1.22;
  font-weight: 700;
  color: #ffffff;
}

.hero-score-section {
  flex: 0 0 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -4rpx;
}

.hero-score {
  min-width: 28rpx;
  text-align: center;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
  color: #ffffff;
}

.hero-score.pending {
  color: rgba(255, 255, 255, 0.56);
}

.hero-score.live {
  color: #00ff85;
}

.hero-score-divider {
  margin: 0 12rpx;
  font-size: 30rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.48);
}

.hero-score-divider.pending {
  margin: 0 14rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.26);
  transform: translateY(-2rpx);
}

.hero-score-divider.live {
  color: #00ff85;
}

.hero-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: flex-start;
  margin-top: 2rpx;
}

.hero-status-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-height: 36rpx;
  padding: 0 12rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.live-chip {
  background: rgba(0, 255, 133, 0.12);
  border-color: rgba(0, 255, 133, 0.18);
}

.hero-status-chip .live-dot {
  margin-right: 0;
}

.hero-status-indicator {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #ffb400;
  box-shadow: 0 0 8rpx rgba(255, 180, 0, 0.28);
  animation: pulse 1.8s ease-in-out infinite;
}

.hero-status-indicator.status-finished {
  background: rgba(255, 255, 255, 0.5);
  box-shadow: none;
  animation: none;
}

.hero-status-indicator.status-delayed {
  background: #ff7b7b;
  box-shadow: 0 0 10rpx rgba(255, 123, 123, 0.34);
}

.hero-status-text {
  font-size: 19rpx;
  font-weight: 600;
}

.hero-status-text.live-text {
  font-size: 19rpx;
  color: #00ff85;
}

.hero-status-text.status-pending {
  color: rgba(255, 255, 255, 0.82);
}

.hero-status-text.status-finished {
  color: rgba(255, 255, 255, 0.78);
}

.hero-status-text.status-delayed {
  color: #ffd6d6;
}
