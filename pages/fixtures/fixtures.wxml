`<view class="container">
  <view class="hero-shell">
    <view class="hero">
      <view class="hero-top-row">
        <view class="hero-arrow" bindtap="prevDate" hover-class="hero-arrow-hover">
          <view class="hero-arrow-icon">
            <pl-icon name="ac/back" size="18" color="#FFFFFF"></pl-icon>
          </view>
        </view>
        <view class="hero-arrow" bindtap="nextDate" hover-class="hero-arrow-hover">
          <view class="hero-arrow-icon">
            <pl-icon name="ac/next" size="18" color="#FFFFFF"></pl-icon>
          </view>
        </view>
      </view>

      <view class="hero-title-group">
        <text class="hero-eyebrow">{{heroEyebrow}}</text>
        <text class="hero-title">{{heroTitle}}</text>
      </view>

      <view class="hero-tabs">
        <view class="hero-tab {{activeTab == 'ALL' ? 'active' : ''}}" bindtap="switchTab" data-tab="ALL">
          全部比赛
        </view>
        <view class="hero-tab {{activeTab == 'LIVE' ? 'active' : ''}}" bindtap="switchTab" data-tab="LIVE">
          进行中
        </view>
        <view class="hero-tab {{activeTab == 'RESULTS' ? 'active' : ''}}" bindtap="switchTab" data-tab="RESULTS">
          已结束
        </view>
      </view>
    </view>
  </view>

  <view class="filters-wrap">
    <view class="filters-card">
      <view class="filters-main" bindtap="showDatePicker">
        <view class="filters-icon">
          <pl-icon name="nav/schedule" size="22" color="#4A2A52"></pl-icon>
        </view>
        <view class="filters-texts">
          <text class="filters-label">{{filterWeek}}</text>
          <text class="filters-date">{{filterDate}}</text>
        </view>
      </view>

      <view class="filters-actions">
        <view class="filters-action" bindtap="showDatePicker">
          <view class="filters-action-icon">
            <pl-icon name="nav/schedule" size="18" color="#4A2A52"></pl-icon>
          </view>
        </view>
        <view class="filters-action" bindtap="showStatusSheet">
          <view class="filters-action-icon">
            <pl-icon name="ac/filter" size="18" color="#4A2A52"></pl-icon>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="content-shell">
    <loading-state wx:if="{{loading && !paneItems.length}}"></loading-state>

    <error-state wx:elif="{{error}}" bind:retry="loadData"></error-state>

    <block wx:else>
      <swiper
        class="content-swiper"
        current="{{swiperCurrent}}"
        duration="260"
        skip-hidden-item-layout="{{true}}"
        bindchange="onSwiperChange">
        <swiper-item wx:for="{{paneItems}}" wx:key="key">
          <scroll-view class="content-pane" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
            <view class="meta-row">
              <text class="matchday-text">{{item.currentMatchday}}</text>
              <text class="cache-text" wx:if="{{item.isCached}}">{{item.cacheTime}}</text>
            </view>

            <view class="matches-list" wx:if="{{item.hasMatches}}">
              <match-card
                wx:for="{{item.matches}}"
                wx:key="id"
                match="{{item}}"
                variant="fixtures"
                bind:tap="onMatchTap">
              </match-card>
            </view>

            <empty-state
              wx:else
              title="该日期暂无比赛"
              description="请选择其他日期查看"
              show-action="{{true}}"
              action-text="切换日期"
              bind:action="showDatePicker">
            </empty-state>

            <view class="load-more" wx:if="{{item.hasMatches}}">
              <text>已经到底了</text>
            </view>
          </scroll-view>
        </swiper-item>
      </swiper>
    </block>
  </view>
</view>
