<view class="container">
  <view class="user-header">
    <view class="user-avatar-wrap" bindtap="onGetUserInfo">
      <image
        wx:if="{{userInfo.avatarUrl}}"
        class="user-avatar"
        src="{{userInfo.avatarUrl || '/images/default/avatar.png'}}"
        mode="aspectFill"
        lazy-load
        />
      <image
        wx:else
        class="user-avatar"
        src="/images/default/avatar.png"
        mode="aspectFill"
        lazy-load
        />
    </view>
    <view class="user-name-wrap">
      <text class="user-name">{{userInfo.nickName || '点击登录'}}</text>
    </view>
    <button
      wx:if="{{!userInfo.nickName}}"
      class="login-btn"
      open-type="chooseAvatar"
      bindchooseavatar="onChooseAvatar">
      获取头像
    </button>
  </view>

  <view class="section">
    <view class="section-header" bindtap="goToFollowedTeams">
      <view class="section-title">
        <view class="section-icon">
          <pl-icon name="ct/bookmark" size="20" color="#38003C"></pl-icon>
        </view>
        <text>我的关注</text>
      </view>
      <view class="section-more">
        <text>{{followedTeams.length > 0 ? followedTeams.length + ' 支' : ''}}</text>
        <view class="arrow-right">
          <pl-icon name="ac/next" size="14" color="#999999"></pl-icon>
        </view>
      </view>
    </view>

    <view class="followed-list" wx:if="{{followedTeams.length > 0}}">
      <view
        class="followed-item"
        wx:for="{{followedTeams}}"
        wx:key="id"
        bindtap="goToTeamDetail"
        data-id="{{item.id}}"
        data-name="{{item.name}}">
        <image class="team-logo" src="{{item.logo || '/images/default/team.png'}}" mode="aspectFit" lazy-load></image>
        <view class="team-info">
          <text class="team-name">{{item.name}}</text>
          <text class="team-rank" wx:if="{{item.rank}}">{{item.rank}}</text>
        </view>
        <view class="arrow">
          <pl-icon name="ac/next" size="16" color="#999999"></pl-icon>
        </view>
      </view>
    </view>

    <view class="followed-empty" wx:else>
      <text>还没有关注球队</text>
      <text class="sub-text">关注你喜欢的球队，快速查看最新动态</text>
    </view>
  </view>

  <view class="section settings-section">
    <view class="settings-list">
      <view class="settings-item" bindtap="clearCache">
        <view class="settings-icon">
          <pl-icon name="sys/settings" size="22" color="#38003C"></pl-icon>
        </view>
        <text class="settings-text">清除缓存</text>
        <text class="settings-extra">{{cacheSize}}</text>
        <view class="arrow">
          <pl-icon name="ac/next" size="16" color="#999999"></pl-icon>
        </view>
      </view>

      <view class="settings-item" bindtap="showAbout">
        <view class="settings-icon">
          <pl-icon name="sys/info" size="22" color="#38003C"></pl-icon>
        </view>
        <text class="settings-text">关于我们</text>
        <view class="arrow">
          <pl-icon name="ac/next" size="16" color="#999999"></pl-icon>
        </view>
      </view>

      <view class="settings-item" bindtap="showFeedback">
        <view class="settings-icon">
          <pl-icon name="ct/comment" size="22" color="#38003C"></pl-icon>
        </view>
        <text class="settings-text">意见反馈</text>
        <view class="arrow">
          <pl-icon name="ac/next" size="16" color="#999999"></pl-icon>
        </view>
      </view>
    </view>
  </view>

  <view class="footer">
    <text class="version">英超资讯小程序 v1.0.0</text>
    <text class="data-source">数据来源于后端 /api 聚合服务</text>
  </view>
</view>
