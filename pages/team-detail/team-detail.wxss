.container {
  padding: 0 30rpx 30rpx;
}

/* 球队头部 */
.team-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  margin: 20rpx 0;
}

.team-logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.team-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.team-venue {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 24rpx;
}

.card-title-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #38003C;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #38003C;
  border-radius: 2rpx;
}

/* Tab 内容 */
.tab-content {
  margin-top: 10rpx;
}

/* 近期战绩 */
.recent-matches {
  display: flex;
  gap: 16rpx;
}

.match-result {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  border-radius: 8rpx;
}

.match-result.win {
  background-color: #E8F5E9;
}

.match-result.draw {
  background-color: #F5F5F5;
}

.match-result.loss {
  background-color: #FFEBEE;
}

.result-text {
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.match-result.win .result-text {
  color: #2E7D32;
}

.match-result.draw .result-text {
  color: #666666;
}

.match-result.loss .result-text {
  color: #C62828;
}

.result-score {
  font-size: 20rpx;
  color: #333333;
  margin-bottom: 4rpx;
}

.result-opponent {
  font-size: 18rpx;
  color: #666666;
}

/* 统计列表 */
.stats-list {
  margin-top: 10rpx;
}

.stat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E5E5E5;
}

.stat-item:last-child {
  border-bottom: none;
}

.stat-label {
  font-size: 28rpx;
  color: #666666;
}

.stat-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

/* 球队信息 */
.info-list {
  margin-top: 10rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E5E5E5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  text-align: right;
  word-break: break-all;
}

.info-value.link {
  color: #38003C;
}

/* 阵容部分 */
.squad-section {
  margin-bottom: 20rpx;
}

.squad-title {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  padding: 20rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx 12rpx 0 0;
  border-bottom: 1rpx solid #E5E5E5;
}

.squad-title-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.squad-list {
  background-color: #FFFFFF;
  border-radius: 0 0 12rpx 12rpx;
  overflow: hidden;
}

.empty-squad,
.empty-fixtures {
  text-align: center;
  padding: 80rpx;
  color: #999999;
  font-size: 28rpx;
}

/* 赛程部分 */
.fixtures-section {
  margin-top: 10rpx;
}

.fixtures-section .section-title {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  padding: 20rpx 0;
}

.section-title-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}
