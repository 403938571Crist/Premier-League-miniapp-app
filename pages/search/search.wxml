<view class="container">
  <view class="search-bar">
    <view class="search-icon">
      <pl-icon name="ac/search" size="20" color="#8E8E93"></pl-icon>
    </view>
    <input
      class="search-input"
      placeholder="搜索球队或球员"
      placeholder-class="search-placeholder"
      value="{{keyword}}"
      bindinput="onKeywordInput"
      focus="{{true}}"
      confirm-type="search">
    </input>
    <view class="clear-btn" wx:if="{{keyword}}" bindtap="onClear">
      <pl-icon name="ac/close" size="14" color="#AAAAAA"></pl-icon>
    </view>
  </view>

  <view class="state-tip" wx:if="{{searching}}">
    <text>搜索中...</text>
  </view>

  <view class="state-tip hint" wx:elif="{{!keyword}}">
    <text>输入球队或球员名称</text>
  </view>

  <view class="state-tip" wx:elif="{{hasSearched && !teams.length && !players.length}}">
    <text>未找到“{{keyword}}”相关结果</text>
  </view>

  <block wx:elif="{{hasSearched}}">
    <view class="result-section" wx:if="{{teams.length}}">
      <view class="result-title">球队（{{teams.length}}）</view>
      <view class="result-list">
        <view
          class="result-item"
          wx:for="{{teams}}"
          wx:key="id"
          bindtap="onTeamTap"
          data-id="{{item.id}}"
          data-name="{{item.name}}">
          <image class="item-crest" src="{{item.crest}}" mode="aspectFit"></image>
          <view class="item-info">
            <text class="item-name">{{item.name}}</text>
            <text class="item-sub">{{item.shortName}}</text>
          </view>
          <view class="arrow-icon">
            <pl-icon name="ac/next" size="16" color="#A0A0A8"></pl-icon>
          </view>
        </view>
      </view>
    </view>

    <view class="result-section" wx:if="{{players.length}}">
      <view class="result-title">球员（{{players.length}}）</view>
      <view class="result-list">
        <view
          class="result-item"
          wx:for="{{players}}"
          wx:key="id"
          bindtap="onPlayerTap"
          data-id="{{item.id}}"
          data-name="{{item.name}}">
          <image class="item-photo" src="{{item.photo}}" mode="aspectFill"></image>
          <view class="item-info">
            <text class="item-name">{{item.name}}</text>
            <text class="item-sub">{{item.positionLabel || item.chinesePosition || item.position}}{{item.nationalityLabel || item.chineseNationality || item.nationality ? ' · ' + (item.nationalityLabel || item.chineseNationality || item.nationality) : ''}}</text>
          </view>
          <view class="arrow-icon">
            <pl-icon name="ac/next" size="16" color="#A0A0A8"></pl-icon>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
