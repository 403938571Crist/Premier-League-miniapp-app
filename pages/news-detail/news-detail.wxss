/* =====================================================
   News Detail — V1 Editorial Hero
   ===================================================== */

.page {
  min-height: 100vh;
  background-color: #F0EDF2;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

/* ── Hero ─────────────────────────────────────────── */
/* padding-top 替代 fixed height，屏幕宽多宽图就多高，
   标题永远不会被截断                                  */
.hero {
  position: relative;
  width: 100%;
  padding-top: 68%;   /* 约 3:2 比例，长标题也装得下 */
  overflow: hidden;
}

.hero-official  { background: linear-gradient(135deg, #38003C 0%, #5B0B62 60%, #7A1C82 100%); }
.hero-dongqiudi { background: linear-gradient(135deg, #1B2566 0%, #3A52CC 55%, #6C82FF 100%); }
.hero-bilibili  { background: linear-gradient(135deg, #8A1E4E 0%, #D6407A 55%, #FF7BA6 100%); }
.hero-douyin    { background: linear-gradient(135deg, #0A0A0A 0%, #3B0A1F 55%, #FE2C55 100%); }
.hero-media     { background: linear-gradient(135deg, #2A1F3F 0%, #4B2F7F 45%, #7A5CFF 100%); }
.hero-romano    { background: linear-gradient(135deg, #3A2200 0%, #8E5A0C 55%, #C98B10 100%); }
.hero-x         { background: linear-gradient(135deg, #0A0A0A 0%, #242424 55%, #505050 100%); }
.hero-sky       { background: linear-gradient(135deg, #003C6E 0%, #0070CC 60%, #29A0FF 100%); }
.hero-guardian  { background: linear-gradient(135deg, #03214A 0%, #052962 60%, #0048A0 100%); }
.hero-reddit    { background: linear-gradient(135deg, #8B1A00 0%, #CC3000 55%, #FF4500 100%); }
.hero-zhibo8    { background: linear-gradient(135deg, #7A1500 0%, #C82600 55%, #E8380D 100%); }

.hero-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
  z-index: 1;
}

.hero-scribble {
  position: absolute;
  inset: 0;
  mix-blend-mode: overlay;
  background: repeating-linear-gradient(110deg, rgba(255,255,255,0.05) 0 4rpx, transparent 4rpx 20rpx);
  z-index: 2;
  pointer-events: none;
}

.hero-shade {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg,
    rgba(10,0,14,0.05) 0%,
    rgba(10,0,14,0.0)  30%,
    rgba(10,0,14,0.70) 75%,
    rgba(10,0,14,0.92) 100%);
  z-index: 2;
}

.hero-chip {
  position: absolute;
  top: 28rpx;
  left: 28rpx;
  height: 44rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  z-index: 3;
}

.hero-chip-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: #38003C;
  flex-shrink: 0;
}

.hero-chip-text {
  font-size: 20rpx;
  font-weight: 800;
  color: #38003C;
  letter-spacing: 2rpx;
}

.hero-overlay {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 32rpx;
  z-index: 3;
}

.hero-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.hero-meta-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
  letter-spacing: 1rpx;
}

.hero-meta-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background-color: #00FF85;
  flex-shrink: 0;
}

.hero-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.38;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: -0.5rpx;
  text-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.4);
}

/* ── Content card ─────────────────────────────────── */
/* 白卡从英雄区下方抬起，四角圆润，和页面背景形成层次 */
.content {
  margin: 0 16rpx;
  padding: 36rpx 32rpx 48rpx;
  background: #FFFFFF;
  border-radius: 0 0 28rpx 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(17, 17, 19, 0.07);
}

/* ── Lede ─────────────────────────────────────────── */
.lede {
  padding-left: 22rpx;
  border-left: 4rpx solid #00FF85;
  margin-bottom: 36rpx;
}

.lede text {
  font-size: 27rpx;
  line-height: 1.78;
  color: #1F1F22;
  font-weight: 500;
  white-space: pre-line;
  word-break: break-word;
}

/* ── Article note ─────────────────────────────────── */
.article-note {
  padding: 22rpx 24rpx;
  border-radius: 14rpx;
  background-color: rgba(56, 0, 60, 0.05);
  margin-bottom: 32rpx;
}

.article-note text {
  font-size: 24rpx;
  line-height: 1.65;
  color: #6E5A74;
}

/* ── Body ─────────────────────────────────────────── */
.body {
  margin-bottom: 8rpx;
}

.body-p {
  margin-bottom: 32rpx;
}

.body-p:last-child {
  margin-bottom: 8rpx;
}

.body-p text {
  font-size: 26rpx;
  line-height: 1.9;
  color: #2C2230;
  white-space: pre-line;
  word-break: break-word;
}

.body-quote {
  margin: 28rpx 0;
  padding: 24rpx 24rpx 24rpx 28rpx;
  border-left: 6rpx solid #00FF85;
  background-color: rgba(0, 255, 133, 0.07);
  border-radius: 0 14rpx 14rpx 0;
}

.body-quote text {
  font-size: 27rpx;
  line-height: 1.6;
  color: #38003C;
  font-weight: 700;
  letter-spacing: -0.3rpx;
}

.body-bullets {
  margin-bottom: 32rpx;
  padding: 22rpx 24rpx;
  background-color: rgba(56, 0, 60, 0.04);
  border-radius: 16rpx;
}

.body-bullet {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.body-bullet:last-child {
  margin-bottom: 0;
}

.body-bullet-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 18rpx;
  border-radius: 50%;
  background-color: #38003C;
  flex-shrink: 0;
}

.body-bullet-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.75;
  color: #333333;
}

.body-image {
  margin: 20rpx 0;
}

.body-img {
  width: 100%;
  border-radius: 14rpx;
  display: block;
}

.no-content {
  padding: 60rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.no-content-text {
  font-size: 26rpx;
  color: #8E8E93;
}

/* ── Content images ───────────────────────────────── */
.content-images {
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.content-img {
  width: 100%;
  display: block;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  background-color: #EDE8F0;
}

.content-img:last-child {
  margin-bottom: 0;
}

/* ── Meta tags ─────────────────────────────────────── */
.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 14rpx;
  padding: 28rpx 0 24rpx;
  margin-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background-color: rgba(56, 0, 60, 0.06);
}

.tag-k {
  font-size: 20rpx;
  font-weight: 500;
  color: #8E8E93;
}

.tag-v {
  font-size: 20rpx;
  font-weight: 700;
  color: #38003C;
}

/* ── Actions ───────────────────────────────────────── */
.actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 32rpx;
}

.btn-primary {
  flex: 1;
  height: 88rpx;
  border-radius: 20rpx;
  background-color: #38003C;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 12rpx 24rpx rgba(56, 0, 60, 0.2);
}

.btn-primary:active { opacity: 0.85; }

.btn-primary-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.btn-primary-chev {
  font-size: 36rpx;
  font-weight: 400;
  color: #00FF85;
  line-height: 1;
}

.btn-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background-color: #F7F3F9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon:active { background-color: #EDE8F0; }
