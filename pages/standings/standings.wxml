<view class="container">
  <view class="tab-bar">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      bindtap="switchTab"
      data-type="{{item.key}}">
      {{item.label}}
    </view>
  </view>

  <loading-state wx:if="{{loading}}" class="flex-fill"></loading-state>

  <error-state wx:elif="{{error}}" class="flex-fill" bind:retry="loadData"></error-state>

  <swiper
    wx:else
    class="rank-swiper"
    current="{{currentTabIndex}}"
    duration="280"
    bindchange="onSwiperChange">

    <!-- STANDINGS -->
    <swiper-item>
      <scroll-view class="pane-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="swiper-pane">
          <view class="table-card">
            <view class="table-header">
              <view class="header-position">Rank</view>
              <view class="header-team">Team</view>
              <view class="header-stats">
                <view class="header-stat">Pts</view>
                <view class="header-stat">W</view>
                <view class="header-stat points">L</view>
              </view>
            </view>

            <view class="cache-tip" wx:if="{{activeTab === 'TOTAL' && isCached}}">
              <text>Cached {{cacheTime}}</text>
            </view>

            <view class="standings-list" wx:if="{{standings.length > 0}}">
              <team-item
                wx:for="{{standings}}"
                wx:key="position"
                team="{{item}}"
                bind:tap="onTeamTap">
              </team-item>
            </view>

            <empty-state
              wx:else
              title="{{tabs[0].emptyTitle}}"
              description="{{tabs[0].emptyDescription}}"
              show-action="{{true}}"
              action-text="Retry"
              bind:action="loadData">
            </empty-state>
          </view>
        </view>

        <view class="legend">
          <view class="legend-item">
            <view class="legend-color champion"></view>
            <text class="legend-text">Champion</text>
          </view>
          <view class="legend-item">
            <view class="legend-color champions-league"></view>
            <text class="legend-text">Champions League</text>
          </view>
          <view class="legend-item">
            <view class="legend-color europa-league"></view>
            <text class="legend-text">Europa League</text>
          </view>
          <view class="legend-item">
            <view class="legend-color relegation"></view>
            <text class="legend-text">Relegation</text>
          </view>
        </view>

        <view class="data-source">
          <text>Data source: backend API</text>
        </view>
      </scroll-view>
    </swiper-item>

    <!-- TOP SCORERS -->
    <swiper-item>
      <scroll-view class="pane-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="swiper-pane">
          <view class="table-card">
            <view class="player-table-header">
              <view class="player-rank-head">Rank</view>
              <view class="player-name-head">Player</view>
              <view class="player-number-head main">Goals</view>
              <view class="player-number-head">Assists</view>
            </view>

            <view class="cache-tip" wx:if="{{activeTab === 'SCORERS' && isCached}}">
              <text>Cached {{cacheTime}}</text>
            </view>

            <view class="player-rank-list" wx:if="{{scorers.length > 0}}">
              <view class="player-rank-row" wx:for="{{scorers}}" wx:key="playerId">
                <view class="player-rank {{index === 0 || index === 1 || index === 2 ? 'top' : ''}}">{{item.rank}}</view>
                <image class="player-avatar" src="{{item.photoUrl || '/images/default/player.png'}}" mode="aspectFill" binderror="onAvatarError" data-list="scorers" data-idx="{{index}}" lazy-load></image>
                <view class="player-info">
                  <text class="player-name">{{item.playerName}}</text>
                  <text class="player-meta">{{item.teamName}} · {{item.position}}</text>
                </view>
                <view class="player-stat main">{{item.goals}}</view>
                <view class="player-stat">{{item.assists}}</view>
              </view>
            </view>

            <empty-state
              wx:else
              title="{{tabs[1].emptyTitle}}"
              description="{{tabs[1].emptyDescription}}"
              show-action="{{true}}"
              action-text="Retry"
              bind:action="loadData">
            </empty-state>
          </view>
        </view>

        <view class="data-source">
          <text>Data source: backend API</text>
        </view>
      </scroll-view>
    </swiper-item>

    <!-- TOP ASSISTS -->
    <swiper-item>
      <scroll-view class="pane-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="swiper-pane">
          <view class="table-card">
            <view class="player-table-header">
              <view class="player-rank-head">Rank</view>
              <view class="player-name-head">Player</view>
              <view class="player-number-head main">Assists</view>
              <view class="player-number-head">Goals</view>
            </view>

            <view class="cache-tip" wx:if="{{activeTab === 'ASSISTS' && isCached}}">
              <text>Cached {{cacheTime}}</text>
            </view>

            <view class="player-rank-list" wx:if="{{assists.length > 0}}">
              <view class="player-rank-row" wx:for="{{assists}}" wx:key="playerId">
                <view class="player-rank {{index === 0 || index === 1 || index === 2 ? 'top' : ''}}">{{item.rank}}</view>
                <image class="player-avatar" src="{{item.photoUrl || '/images/default/player.png'}}" mode="aspectFill" binderror="onAvatarError" data-list="assists" data-idx="{{index}}" lazy-load></image>
                <view class="player-info">
                  <text class="player-name">{{item.playerName}}</text>
                  <text class="player-meta">{{item.teamName}} · {{item.position}}</text>
                </view>
                <view class="player-stat main">{{item.assists}}</view>
                <view class="player-stat">{{item.goals}}</view>
              </view>
            </view>

            <empty-state
              wx:else
              title="{{tabs[2].emptyTitle}}"
              description="{{tabs[2].emptyDescription}}"
              show-action="{{true}}"
              action-text="Retry"
              bind:action="loadData">
            </empty-state>
          </view>
        </view>

        <view class="data-source">
          <text>Data source: backend API</text>
        </view>
      </scroll-view>
    </swiper-item>

  </swiper>
</view>
