.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #FFFFFF;
  border-top: 2rpx solid rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: stretch;
  justify-content: space-around;
  z-index: 999;
  box-shadow: 0 -4rpx 16rpx rgba(17, 17, 19, 0.04);
  height: calc(120rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
}

.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  padding-top: 12rpx;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  display: block;
}

.tab-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #8E8E93;
  margin-top: 6rpx;
  letter-spacing: 0.5rpx;
}

.tab-text-on {
  color: #38003C;
  font-weight: 800;
}

.tab-tick {
  width: 40rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background-color: #00FF85;
  margin-top: 8rpx;
}
