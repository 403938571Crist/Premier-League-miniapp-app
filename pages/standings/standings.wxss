/* 让 page 本身高度 = 屏幕高度，这样 flex 子元素才能正确撑满 */
page {
  height: 100%;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 0 30rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.tab-bar {
  display: flex;
  margin: 20rpx 0 18rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f7f2f8 100%);
  border-radius: 18rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 24rpx rgba(17, 17, 19, 0.05);
}

.tab-item {
  position: relative;
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #8e8e93;
  font-weight: 600;
}

.tab-item.active {
  color: #38003c;
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 10rpx;
  transform: translateX(-50%);
  width: 42rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background-color: #00ff85;
}

.hero-card {
  margin-bottom: 20rpx;
  padding: 28rpx 28rpx 30rpx;
  border-radius: 20rpx;
  background:
    radial-gradient(circle at top right, rgba(0, 255, 133, 0.2), transparent 34%),
    linear-gradient(135deg, #38003c 0%, #210023 100%);
  box-shadow: 0 14rpx 32rpx rgba(56, 0, 60, 0.18);
}

.hero-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #ffffff;
}

.hero-description {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.76);
}

/* Swiper 撑满容器剩余高度，内部各 pane 用 scroll-view 滚动。
   不再需要 JS 算高度。 */
.rank-swiper {
  flex: 1;
  min-height: 0; /* 关键：让 flex 子元素可以收缩 */
  overflow: hidden;
}

.pane-scroll {
  height: 100%;
  box-sizing: border-box;
}

.swiper-pane {
  padding: 0 2rpx 20rpx;
  box-sizing: border-box;
}

/* loading / error 也撑满剩余区域 */
.flex-fill {
  flex: 1;
  min-height: 0;
}

.table-card,
.placeholder-card {
  overflow: hidden;
  background-color: #ffffff;
  border-radius: 18rpx;
  box-shadow: 0 10rpx 24rpx rgba(17, 17, 19, 0.04);
}

.table-header {
  display: flex;
  align-items: center;
  height: 84rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #ececf1;
  font-size: 24rpx;
  color: #b0b0b5;
}

.header-position {
  width: 68rpx;
  text-align: center;
}

.header-team {
  flex: 1;
  margin-left: 80rpx;
}

.header-stats {
  display: flex;
  align-items: center;
}

.header-stat {
  width: 74rpx;
  text-align: center;
}

.header-stat.points {
  color: #38003c;
  font-weight: 700;
}

.cache-tip {
  margin: 16rpx 20rpx 0;
  padding: 14rpx 18rpx;
  border-radius: 12rpx;
  background-color: rgba(255, 152, 0, 0.1);
}

.cache-tip text {
  font-size: 22rpx;
  color: #ff9800;
}

.standings-list {
  background-color: #ffffff;
}

.player-table-header {
  display: flex;
  align-items: center;
  height: 84rpx;
  padding: 0 22rpx;
  border-bottom: 1rpx solid #ececf1;
  font-size: 24rpx;
  color: #b0b0b5;
  box-sizing: border-box;
}

.player-rank-head {
  width: 64rpx;
  text-align: center;
}

.player-name-head {
  flex: 1;
  margin-left: 96rpx;
}

.player-number-head {
  width: 78rpx;
  text-align: center;
}

.player-number-head.main {
  color: #38003c;
  font-weight: 700;
}

.player-rank-list {
  background-color: #ffffff;
}

.player-rank-row {
  display: flex;
  align-items: center;
  min-height: 108rpx;
  padding: 18rpx 22rpx;
  border-bottom: 1rpx solid #f0edf3;
  box-sizing: border-box;
}

.player-rank-row:last-child {
  border-bottom: none;
}

.player-rank {
  width: 64rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 800;
  color: #8e8e93;
}

.player-rank.top {
  color: #38003c;
}

.player-avatar {
  width: 76rpx;
  height: 76rpx;
  margin-left: 18rpx;
  border-radius: 50%;
  background-color: #ede8f0;
  border: 2rpx solid #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(56, 0, 60, 0.1);
  flex-shrink: 0;
}

/* 图片加载失败时隐藏破图，背景色充当占位 */
.player-avatar-error {
  opacity: 0;
}

.player-info {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.player-name {
  display: block;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #2b1030;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.3;
  color: #8e8e93;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-stat {
  width: 78rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #7a6c7d;
}

.player-stat.main {
  font-size: 34rpx;
  color: #38003c;
}

.placeholder-card {
  padding: 32rpx 28rpx 36rpx;
}

.placeholder-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 136rpx;
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(56, 0, 60, 0.08);
}

.placeholder-badge text {
  font-size: 24rpx;
  font-weight: 700;
  color: #38003c;
}

.placeholder-title {
  display: block;
  margin-top: 24rpx;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #1f1f23;
}

.placeholder-description {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6a6a72;
}

.legend {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 24rpx;
  padding: 30rpx 0;
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.legend-color.champion {
  background-color: #ffd700;
}

.legend-color.champions-league {
  background-color: #38003c;
}

.legend-color.europa-league {
  background-color: #00ff85;
}

.legend-color.relegation {
  background-color: #ff5252;
}

.legend-text {
  font-size: 22rpx;
  color: #666666;
}

.data-source {
  text-align: center;
  /* 160rpx = 自定义底部 tab 栏高度，safe-area 适配刘海屏 */
  padding: 10rpx 0 calc(160rpx + env(safe-area-inset-bottom));
}

.data-source text {
  font-size: 22rpx;
  color: #a1a1a8;
}
