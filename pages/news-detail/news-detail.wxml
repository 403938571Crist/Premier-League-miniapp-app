<loading-state wx:if="{{loading}}"></loading-state>

<view class="page" wx:elif="{{!notFound && article}}">
  <view class="hero hero-{{article.coverTheme}}">
    <image
      wx:if="{{article.hasImage}}"
      class="hero-img"
      src="{{article.coverImage}}"
      mode="aspectFill"
      lazy-load
      binderror="onHeroImageError"
    />
    <view class="hero-scribble"></view>
    <view class="hero-shade"></view>

    <view class="hero-chip" style="background-color: {{article.coverAccent}};">
      <view class="hero-chip-dot"></view>
      <text class="hero-chip-text">{{article.coverLabel}}</text>
    </view>

    <view class="hero-overlay">
      <view class="hero-meta">
        <text class="hero-meta-text">{{sourceLabel}}</text>
        <view class="hero-meta-dot"></view>
        <text class="hero-meta-text">{{article.publishedAt}}</text>
      </view>
      <text class="hero-title">{{article.title}}</text>
    </view>
  </view>

  <view class="content">
    <view class="cache-tip" wx:if="{{article.isCached && article.cacheTimeText}}">
      <text>当前展示的是缓存内容，{{article.cacheTimeText}}</text>
    </view>

    <view class="lede" wx:if="{{article.showLede}}">
      <text>{{article.lede}}</text>
    </view>

    <view class="article-note" wx:if="{{article.sourceNote}}">
      <text>{{article.sourceNote}}</text>
    </view>

    <view class="body" wx:if="{{article.blocks.length > 0}}">
      <block wx:for="{{article.blocks}}" wx:key="index">
        <view class="body-p" wx:if="{{item.type === 'paragraph'}}">
          <text>{{item.text}}</text>
        </view>
        <view class="body-quote" wx:elif="{{item.type === 'quote'}}">
          <text>{{item.text}}</text>
        </view>
        <view class="body-bullets" wx:elif="{{item.type === 'bullet'}}">
          <view class="body-bullet" wx:for="{{item.items}}" wx:for-item="bullet" wx:key="index">
            <view class="body-bullet-dot"></view>
            <text class="body-bullet-text">{{bullet}}</text>
          </view>
        </view>
      </block>
    </view>

    <view class="body no-content" wx:elif="{{!article.showLede}}">
      <text class="no-content-text">点击下方按钮查看完整文章</text>
    </view>

    <view class="content-images" wx:if="{{article.hasContentImages}}">
      <image
        wx:for="{{article.contentImages}}"
        wx:key="index"
        class="content-img"
        src="{{item}}"
        mode="widthFix"
        lazy-load
        show-menu-by-longpress
        binderror="onContentImageError"
        data-index="{{index}}"
      ></image>
    </view>

    <view class="meta-row">
      <view class="tag">
        <text class="tag-k">来源</text>
        <text class="tag-v">{{article.source}}</text>
      </view>
      <view class="tag">
        <text class="tag-k">类型</text>
        <text class="tag-v">{{article.mediaTypeLabel}}</text>
      </view>
      <view class="tag" wx:if="{{article.author}}">
        <text class="tag-k">作者</text>
        <text class="tag-v">{{article.author}}</text>
      </view>
    </view>

    <view class="actions" wx:if="{{article.url}}">
      <view class="btn-primary" bindtap="onOpenWebview">
        <text class="btn-primary-text">{{article.openActionText}}</text>
        <text class="btn-primary-chev">→</text>
      </view>
      <view class="btn-icon" bindtap="onCopyLink" hover-class="btn-icon-hover">
        <pl-icon name="ct/link" size="{{32}}" color="#38003C"></pl-icon>
      </view>
      <view class="btn-icon" bindtap="onShare" hover-class="btn-icon-hover">
        <pl-icon name="ct/share" size="{{32}}" color="#38003C"></pl-icon>
      </view>
    </view>
  </view>
</view>

<view class="page" wx:else>
  <empty-state
    title="资讯不存在"
    description="{{errorMessage || '当前资讯详情未找到'}}"
    show-action="{{false}}">
  </empty-state>
</view>
