<view class="container">
  <!-- 用户信息头部 -->
  <view class="user-header">
    <view class="user-avatar">
      <open-data type="userAvatarUrl" default-avatar="/images/default/avatar.png"></open-data>
    </view>
    <view class="user-name">
      <open-data type="userNickName" default-text="微信用户"></open-data>
    </view>
  </view>

  <!-- 我的关注 -->
  <view class="section">
    <view class="section-header" bindtap="goToFollowedTeams">
      <view class="section-title">
        <image class="section-icon" src="/images/icons/star.png" mode="aspectFit"></image>
        <text>我的关注</text>
      </view>
      <view class="section-more">
        <text>{{followedTeams.length > 0 ? followedTeams.length + ' 支' : ''}}</text>
        <text class="arrow-right"></text>
      </view>
    </view>

    <!-- 关注的球队列表 -->
    <view class="followed-list" wx:if="{{followedTeams.length > 0}}">
      <view 
        class="followed-item" 
        wx:for="{{followedTeams}}" 
        wx:key="id"
        bindtap="goToTeamDetail"
        data-id="{{item.id}}"
        data-name="{{item.name}}">
        <image class="team-logo" src="{{item.logo}}" mode="aspectFit"></image>
        <view class="team-info">
          <text class="team-name">{{item.name}}</text>
          <text class="team-rank" wx:if="{{item.rank}}">{{item.rank}}</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="followed-empty" wx:else>
      <text>还没有关注球队</text>
      <text class="sub-text">关注你喜欢的球队，快速查看最新动态</text>
    </view>
  </view>

  <!-- 设置列表 -->
  <view class="section settings-section">
    <view class="settings-list">
      <view class="settings-item" bindtap="clearCache">
        <image class="settings-icon" src="/images/icons/settings.png" mode="aspectFit"></image>
        <text class="settings-text">清除缓存</text>
        <text class="settings-extra">{{cacheSize}}</text>
        <text class="arrow">›</text>
      </view>
      
      <view class="settings-item" bindtap="showAbout">
        <image class="settings-icon" src="/images/icons/about.png" mode="aspectFit"></image>
        <text class="settings-text">关于我们</text>
        <text class="arrow">›</text>
      </view>
      
      <view class="settings-item" bindtap="showFeedback">
        <image class="settings-icon" src="/images/icons/feedback.png" mode="aspectFit"></image>
        <text class="settings-text">意见反馈</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="version">英超资讯小程序 v1.0.0</text>
    <text class="data-source">数据来源于后端 /api 聚合服务</text>
  </view>
</view>
