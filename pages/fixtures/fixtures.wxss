.container {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #38003c 0, #38003c 430rpx, #f5f5f7 430rpx, #f5f5f7 100%);
}

.hero-shell {
  padding: 28rpx 30rpx 0;
}

.hero {
  padding: 20rpx 0 68rpx;
}

.hero-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-arrow {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.hero-arrow-hover,
.hero-arrow:active {
  opacity: 0.75;
  transform: scale(0.98);
}

.hero-arrow-icon {
  width: 22rpx;
  height: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-title-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 28rpx;
  padding: 0 48rpx;
}

.hero-eyebrow {
  font-size: 22rpx;
  line-height: 1.2;
  letter-spacing: 2rpx;
  color: #00ff85;
  font-weight: 700;
  text-align: center;
}

.hero-title {
  margin-top: 10rpx;
  font-size: 52rpx;
  line-height: 1.04;
  color: #ffffff;
  font-weight: 800;
  letter-spacing: -0.8rpx;
  text-align: center;
}

.hero-tabs {
  display: flex;
  justify-content: center;
  gap: 18rpx;
  margin-top: 34rpx;
}

.hero-tab {
  min-width: 156rpx;
  height: 68rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.48);
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.hero-tab.active {
  color: #2c1133;
  background-color: #00ff85;
  box-shadow: 0 14rpx 28rpx rgba(0, 255, 133, 0.18);
}

.filters-wrap {
  margin-top: -34rpx;
  padding: 0 30rpx;
}

.filters-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 22rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 18rpx 36rpx rgba(34, 18, 43, 0.14);
}

.filters-main {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.filters-icon {
  width: 30rpx;
  height: 30rpx;
  opacity: 0.72;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filters-texts {
  display: flex;
  flex-direction: column;
  margin-left: 18rpx;
  min-width: 0;
  flex: 1;
}

.filters-label {
  font-size: 18rpx;
  line-height: 1.2;
  color: #a0a0a8;
  font-weight: 700;
  letter-spacing: 1.6rpx;
}

.filters-date {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.2;
  color: #4a2a52;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.filters-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: 16rpx;
}

.filters-action {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f6f6f8;
}

.filters-action-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.72;
  display: flex;
  align-items: center;
  justify-content: center;
}

.content-shell {
  padding: 22rpx 30rpx 30rpx;
}

.content-swiper {
  height: calc(100vh - 500rpx);
}

.content-pane {
  height: 100%;
  box-sizing: border-box;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 6rpx 20rpx;
}

.matchday-text {
  font-size: 22rpx;
  color: rgba(74, 42, 82, 0.46);
  letter-spacing: 2rpx;
  font-weight: 700;
}

.cache-text {
  font-size: 20rpx;
  color: #00b86b;
  font-weight: 600;
}

.matches-list {
  margin-top: 2rpx;
}

.load-more {
  text-align: center;
  padding: 36rpx 0 10rpx;
}

.load-more text {
  font-size: 22rpx;
  color: #b0b0b5;
}
