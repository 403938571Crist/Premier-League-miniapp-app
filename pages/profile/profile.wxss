.container {
  padding: 0 30rpx 30rpx;
}

/* 用户头部 */
.user-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  margin: 20rpx 0;
}

.user-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 20rpx;
  background-color: #F5F5F5;
}

.user-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-name-wrap {
  margin-bottom: 12rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.login-btn {
  font-size: 24rpx;
  color: #38003C;
  background: transparent;
  border: 1rpx solid #38003C;
  border-radius: 32rpx;
  padding: 8rpx 32rpx;
  line-height: 1.6;
  margin-top: 8rpx;
}

/* 分组标题 */
.section {
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.section-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999999;
}

.arrow-right {
  width: 24rpx;
  height: 24rpx;
  margin-left: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 关注的球队列表 */
.followed-list {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
}

.followed-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.followed-item:last-child {
  border-bottom: none;
}

.followed-item:active {
  background-color: #F5F5F5;
}

.followed-item .team-logo {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
}

.followed-item .team-info {
  flex: 1;
  min-width: 0;
}

.followed-item .team-name {
  font-size: 28rpx;
  color: #333333;
  display: block;
}

.followed-item .team-rank {
  font-size: 24rpx;
  color: #666666;
  margin-top: 4rpx;
  display: block;
}

.followed-item .arrow {
  width: 28rpx;
  height: 28rpx;
  margin-left: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 关注空状态 */
.followed-empty {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 60rpx 30rpx;
  text-align: center;
}

.followed-empty text {
  display: block;
  font-size: 28rpx;
  color: #666666;
}

.followed-empty .sub-text {
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
}

/* 设置列表 */
.settings-section {
  margin-top: 10rpx;
}

.settings-list {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  height: 100rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item:active {
  background-color: #F5F5F5;
}

.settings-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.settings-extra {
  font-size: 24rpx;
  color: #999999;
  margin-right: 16rpx;
}

.settings-item .arrow {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 底部信息 */
.footer {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.version {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.data-source {
  display: block;
  font-size: 22rpx;
  color: #CCCCCC;
}
