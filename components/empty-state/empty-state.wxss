.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 60rpx;
  text-align: center;
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 40rpx;
}

.empty-icon-placeholder {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 40rpx;
  background-color: #F5F5F5;
  border-radius: 50%;
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.empty-action {
  margin-top: 20rpx;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  padding: 0 48rpx;
  font-size: 28rpx;
  border-radius: 32rpx;
}

.btn-primary {
  background-color: #38003C;
  color: #FFFFFF;
}

.btn-primary:active {
  opacity: 0.8;
}
