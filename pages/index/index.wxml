<view class="container">
  <!-- 搜索栏和日期选择 -->
  <view class="search-bar">
    <view class="search-input" bindtap="onSearchTap">
      <image class="search-icon" src="/images/icons/search.png" mode="aspectFit"></image>
      <text class="search-placeholder">搜索球队或球员</text>
    </view>
    <view class="date-picker" bindtap="onDatePick">
      <image class="date-icon" src="/images/icons/calendar.png" mode="aspectFit"></image>
    </view>
  </view>

  <!-- 加载状态 -->
  <loading-state wx:if="{{loading && !featuredMatches.length}}"></loading-state>

  <!-- 错误状态 -->
  <error-state 
    wx:elif="{{error}}" 
    title="{{error.title}}"
    description="{{error.description}}"
    bind:retry="loadData">
  </error-state>

  <!-- 内容区域 -->
  <block wx:else>
    <!-- 焦点比赛轮播 -->
    <view class="featured-section" wx:if="{{featuredMatches.length > 0}}">
      <view class="featured-head">
        <view class="featured-copy">
          <text class="featured-eyebrow">MATCHDAY FOCUS</text>
          <text class="featured-title">焦点比赛</text>
        </view>
        <view class="featured-badge">
          <text>{{featuredMatches.length}} 场</text>
        </view>
      </view>
      <view class="featured-shell">
        <swiper
          class="featured-swiper"
          indicator-dots
          autoplay="{{false}}"
          circular="{{false}}"
          duration="220">
          <swiper-item wx:for="{{featuredMatches}}" wx:key="id">
            <view class="featured-card-wrap">
              <match-card 
                match="{{item}}" 
                is-highlight="{{true}}"
                bind:tap="onMatchTap">
              </match-card>
            </view>
          </swiper-item>
        </swiper>
      </view>
    </view>

    <!-- 快捷入口 -->
    <view class="quick-access">
      <view class="quick-item" bindtap="goToStandings">
        <view class="quick-icon-wrap">
          <image class="quick-icon" src="/images/icons/trophy.png" mode="aspectFit"></image>
        </view>
        <text class="quick-text">积分榜</text>
        <text class="quick-subtext">实时排名</text>
      </view>
      <view class="quick-item" bindtap="goToFixtures">
        <view class="quick-icon-wrap">
          <image class="quick-icon" src="/images/icons/calendar.png" mode="aspectFit"></image>
        </view>
        <text class="quick-text">赛程</text>
        <text class="quick-subtext">比赛日历</text>
      </view>
      <view class="quick-item" bindtap="goToTeams">
        <view class="quick-icon-wrap">
          <image class="quick-icon" src="/images/icons/team.png" mode="aspectFit"></image>
        </view>
        <text class="quick-text">球队</text>
        <text class="quick-subtext">俱乐部档案</text>
      </view>
    </view>

    <!-- 英超资讯 -->
    <view class="section">
      <view class="section-header">
        <view class="section-title">
          <image class="section-icon" src="/images/icons/list.png" mode="aspectFit"></image>
          <text>英超资讯</text>
        </view>
      </view>

      <!-- 缓存提示 -->
      <view class="cache-tip" wx:if="{{isCached}}">
        <text>数据来自缓存 · {{cacheTime}}</text>
      </view>

      <!-- 资讯列表 -->
      <view class="news-list" wx:if="{{newsItems.length > 0}}">
        <view
          class="news-card"
          wx:for="{{newsItems}}"
          wx:key="id"
          bindtap="onNewsTap"
          data-id="{{item.id}}">
          <view class="news-cover news-cover-{{item.coverTheme}}">
            <view class="news-cover-top">
              <text class="news-cover-tag">{{item.tag}}</text>
              <text class="news-cover-type">{{item.mediaType}}</text>
            </view>
            <view class="news-cover-body">
              <image class="news-cover-icon" src="/images/icons/news.png" mode="aspectFit"></image>
              <view class="news-cover-copy">
                <text class="news-cover-source">{{item.source}}</text>
                <text class="news-cover-title">{{item.title}}</text>
              </view>
            </view>
          </view>
          <view class="news-card-head">
            <text class="news-tag">{{item.source}}</text>
            <text class="news-date">{{item.publishedAt}}</text>
          </view>
          <text class="news-card-title">{{item.title}}</text>
          <text class="news-card-summary">{{item.summary}}</text>
          <view class="news-card-footer">
            <text class="news-source">{{item.mediaType}}</text>
            <image class="news-arrow" src="/images/icons/arrow-right.png" mode="aspectFit"></image>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <empty-state 
        wx:else
        title="暂无资讯"
        description="稍后再来查看最新英超动态">
      </empty-state>
    </view>

    <view class="section social-section">
      <view class="section-header">
        <view class="section-title">
          <image class="section-icon" src="/images/icons/star.png" mode="aspectFit"></image>
          <text>球员社媒</text>
        </view>
      </view>

      <view class="social-list">
        <view
          class="social-card"
          wx:for="{{socialItems}}"
          wx:key="id"
          bindtap="onSocialTap"
          data-id="{{item.id}}">
          <view class="social-avatar">{{item.playerName[0]}}</view>
          <view class="social-main">
            <view class="social-top">
              <text class="social-name">{{item.playerName}}</text>
              <text class="social-platform">{{item.platform}}</text>
            </view>
            <text class="social-handle">{{item.handle}}</text>
            <text class="social-summary">{{item.team}} · {{item.summary}}</text>
          </view>
          <image class="social-arrow" src="/images/icons/arrow-right.png" mode="aspectFit"></image>
        </view>
      </view>
    </view>
  </block>
</view>
