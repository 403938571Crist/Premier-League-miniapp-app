<view class="follow-btn {{isFollowing ? 'following' : ''}} {{loading ? 'loading' : ''}}" bindtap="onTap">
  <block wx:if="{{loading}}">
    <view class="loading-dots">
      <text>.</text>
      <text>.</text>
      <text>.</text>
    </view>
  </block>
  <block wx:elif="{{isFollowing}}">
    <text class="check-icon">✓</text>
    <text>已关注</text>
  </block>
  <block wx:else>
    <text class="plus-icon">+</text>
    <text>关注</text>
  </block>
</view>
